{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src",
    "components",
    "context",
    "hooks",
    "services",
    "types",
    "utils",
    "views",
    "App.tsx",
    "main.tsx",
    "vite-env.d.ts"
  ],
  "exclude": [
    "server",
    "bridge-agent",
    "temp_reception.tsx",
    "services/testDb.ts"
  ]
}